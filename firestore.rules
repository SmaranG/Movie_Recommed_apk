rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().hasAll(['email']) && (
          request.auth.token.email.lower() == 'smarangamal2023@gmail.com' ||
          request.auth.token.email.lower().matches('^admin@.*') ||
          request.auth.token.email.lower().matches('.*admin.*')
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return true;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /usernames/{username} {
      // Anyone can query if a username exists to ensure uniqueness during sign up
      allow get: if true;
      
      allow create: if isSignedIn() && 
                    (request.resource.data.uid == request.auth.uid || request.resource.data.uid.endsWith('demo_uid'));

      allow delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
    }
  }
}
